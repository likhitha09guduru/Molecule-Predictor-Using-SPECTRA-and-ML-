{
    "data_dir": "artifacts/data/converted",
    "output_dir": "artifacts/models/",
    "epochs": 1,
    "batch_size": 8,
    "hidden_dim": 64,
    "fusion_type": "concat",
    "target_type": "regression",
    "max_peaks_ms": 200,
    "max_peaks_nmr": 150,
    "max_peaks_ir": 100,
    "noise_threshold_ms": 0.01,
    "noise_threshold_nmr": 0.001,
    "noise_threshold_ir": 0.01,
    "normalize": true,
    "shuffle_train": true,
    "num_workers": 0,
    "num_heads": 4,
    "num_layers": 3,
    "dropout": 0.1,
    "output_dim": 1,
    "learning_rate": 0.001,
    "weight_decay": 1e-05,
    "early_stopping_patience": 20,
    "scheduler_patience": 10,
    "scheduler_factor": 0.5,
    "clip_grad_norm": 1.0,
    "log_interval": 10,
    "use_all_modalities": true
}